---
import Base from "../layouts/Base.astro";
---

<Base title="Bilera mini-sites">
  <main class="min-h-screen flex items-center justify-center px-6">
    <div class="text-center space-y-3 max-w-lg">
      <h1 class="text-3xl font-bold">Bilera mini-sites</h1>
      <p class="text-gray-500">
        Cada asociación accede a su página pública por slug:{" "}
        <code class="text-sm bg-gray-100 px-1.5 py-0.5 rounded">/mi-asociacion</code>.
      </p>
    </div>
  </main>
</Base>
