---
import Base from "../layouts/Base.astro";
import { fetchSite, heroImageUrl, themeColors } from "../lib/api";

const { slug } = Astro.params;

let site = null;
let error: string | null = null;

if (slug) {
  try {
    site = await fetchSite(slug);
  } catch (e) {
    error = (e as Error).message;
  }
}

if (!site) {
  Astro.response.status = 404;
}

const heroTitle = site?.config.hero?.title || site?.tenant.name || "";
const heroSubtitle = site?.config.hero?.subtitle || "";
const aboutText = site?.config.about?.text;
const hasHero = !!site?.tenant.hasHero;
const heroUrl = hasHero && site ? heroImageUrl(site.tenant.slug) : null;
const theme = themeColors(site?.tenant.theme || "default");
---

{!site ? (
  <Base title="Sitio no encontrado">
    <main class="min-h-screen flex items-center justify-center px-6">
      <div class="text-center space-y-2">
        <h1 class="text-3xl font-bold">Sitio no encontrado</h1>
        <p class="text-gray-500">
          {error ? `Error: ${error}` : `No existe ningún mini-site en /${slug}.`}
        </p>
      </div>
    </main>
  </Base>
) : (
  <Base title={site.tenant.name} description={heroSubtitle}>
    <main>
      <section
        class="relative min-h-[70vh] flex items-center justify-center overflow-hidden"
        style={`background: ${
          heroUrl
            ? ""
            : `linear-gradient(135deg, ${theme.gradientFrom} 0%, ${theme.gradientTo} 100%)`
        };`}
      >
        {heroUrl && (
          <>
            <img
              src={heroUrl}
              alt=""
              class="absolute inset-0 w-full h-full object-cover"
            />
            <div class="absolute inset-0 bg-black/35"></div>
          </>
        )}
        <div class={`relative z-10 text-center px-6 py-24 max-w-3xl ${heroUrl ? "text-white" : ""}`}>
          <h1 class="text-4xl md:text-6xl font-bold tracking-tight">
            {heroTitle}
          </h1>
          {heroSubtitle && (
            <p class={`mt-6 text-lg md:text-2xl ${heroUrl ? "text-white/90" : ""}`} style={heroUrl ? "" : `color: ${theme.primary};`}>
              {heroSubtitle}
            </p>
          )}
        </div>
      </section>

      {aboutText && (
        <section class="max-w-3xl mx-auto px-6 py-20">
          <div class="flex items-center gap-3 mb-6">
            <span class="h-1 w-10 rounded-full" style={`background: ${theme.primary};`}></span>
            <h2 class="text-2xl md:text-3xl font-semibold">Sobre nosotros</h2>
          </div>
          <p class="text-gray-700 whitespace-pre-line leading-relaxed text-lg">{aboutText}</p>
        </section>
      )}

      <footer class="border-t mt-8 py-10 text-center text-sm text-gray-500">
        {site.tenant.name}
      </footer>
    </main>
  </Base>
)}
