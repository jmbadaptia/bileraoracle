---
import Base from "../layouts/Base.astro";
import { fetchSite } from "../lib/api";

const { slug } = Astro.params;

let site = null;
let error: string | null = null;

if (slug) {
  try {
    site = await fetchSite(slug);
  } catch (e) {
    error = (e as Error).message;
  }
}

if (!site) {
  Astro.response.status = 404;
}

const heroTitle = site?.config.hero?.title || site?.tenant.name || "";
const heroSubtitle = site?.config.hero?.subtitle || "";
const heroImage = site?.config.hero?.imageUrl;
const aboutText = site?.config.about?.text;
---

{!site ? (
  <Base title="Sitio no encontrado">
    <main class="min-h-screen flex items-center justify-center px-6">
      <div class="text-center space-y-2">
        <h1 class="text-3xl font-bold">Sitio no encontrado</h1>
        <p class="text-gray-500">
          {error ? `Error: ${error}` : `No existe ningún mini-site en /${slug}.`}
        </p>
      </div>
    </main>
  </Base>
) : (
  <Base title={site.tenant.name} description={heroSubtitle}>
    <main>
      <section class="relative min-h-[60vh] flex items-center justify-center overflow-hidden bg-gray-50">
        {heroImage && (
          <img
            src={heroImage}
            alt=""
            class="absolute inset-0 w-full h-full object-cover opacity-40"
          />
        )}
        <div class="relative z-10 text-center px-6 py-20 max-w-3xl">
          <h1 class="text-4xl md:text-6xl font-bold tracking-tight">
            {heroTitle}
          </h1>
          {heroSubtitle && (
            <p class="mt-4 text-lg md:text-xl text-gray-600">{heroSubtitle}</p>
          )}
        </div>
      </section>

      {aboutText && (
        <section class="max-w-3xl mx-auto px-6 py-16">
          <h2 class="text-2xl font-semibold mb-4">Sobre nosotros</h2>
          <p class="text-gray-700 whitespace-pre-line leading-relaxed">{aboutText}</p>
        </section>
      )}

      <footer class="border-t mt-16 py-8 text-center text-sm text-gray-500">
        {site.tenant.name}
      </footer>
    </main>
  </Base>
)}
