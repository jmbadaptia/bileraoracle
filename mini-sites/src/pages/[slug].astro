---
import MiniSiteLayout from "../layouts/MiniSiteLayout.astro";
import Base from "../layouts/Base.astro";
import { fetchSite, fetchEvents, fetchCourses, fetchGallery, composeSiteConfig } from "../lib/api";

const { slug } = Astro.params;

let site = null;
let events: any[] = [];
let courses: any[] = [];
let photos: any[] = [];
let error: string | null = null;

if (slug) {
  try {
    const [siteRes, eventsRes, coursesRes, photosRes] = await Promise.all([
      fetchSite(slug),
      fetchEvents(slug),
      fetchCourses(slug),
      fetchGallery(slug),
    ]);
    site = siteRes;
    events = eventsRes;
    courses = coursesRes;
    photos = photosRes;
  } catch (e) {
    error = (e as Error).message;
  }
}

if (!site) {
  Astro.response.status = 404;
}

const siteConfig = site ? composeSiteConfig(site, events, courses, photos) : null;
---

{!siteConfig ? (
  <Base title="Sitio no encontrado">
    <main class="min-h-screen flex items-center justify-center px-6">
      <div class="text-center space-y-2">
        <h1 class="text-3xl font-bold">Sitio no encontrado</h1>
        <p class="text-gray-500">
          {error ? `Error: ${error}` : `No existe ningún mini-site en /${slug}.`}
        </p>
      </div>
    </main>
  </Base>
) : (
  <MiniSiteLayout siteConfig={siteConfig} />
)}
