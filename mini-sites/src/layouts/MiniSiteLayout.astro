---
import type { SiteConfig } from "../lib/api";
import SiteNav from "../components/SiteNav.astro";
import HeroSection from "../components/HeroSection.astro";
import SobreNosotros from "../components/SobreNosotros.astro";
import ProximosEventos from "../components/ProximosEventos.astro";
import CursosInscripcion from "../components/CursosInscripcion.astro";
import GaleriaFotos from "../components/GaleriaFotos.astro";
import ContactoSection from "../components/ContactoSection.astro";
import SiteFooter from "../components/SiteFooter.astro";

interface Props {
  siteConfig: SiteConfig;
}

const { siteConfig } = Astro.props;
const { nombre, subtitulo, heroImageUrl, colorTema, bloques } = siteConfig;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={subtitulo} />
    <title>{nombre}</title>

    <meta property="og:type" content="website" />
    <meta property="og:title" content={nombre} />
    <meta property="og:description" content={subtitulo} />
    <meta property="og:image" content={heroImageUrl} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-white text-neutral-900 antialiased" style={`--color-tema: ${colorTema};`}>
    <SiteNav siteConfig={siteConfig} />
    <main>
      <HeroSection siteConfig={siteConfig} />
      {bloques.sobreNosotros && siteConfig.sobreNosotros && (
        <SobreNosotros siteConfig={siteConfig} />
      )}
      {bloques.eventos && siteConfig.eventos && siteConfig.eventos.length > 0 && (
        <ProximosEventos siteConfig={siteConfig} />
      )}
      {bloques.cursos && siteConfig.cursos && siteConfig.cursos.length > 0 && (
        <CursosInscripcion siteConfig={siteConfig} />
      )}
      {bloques.galeria && siteConfig.galeria && siteConfig.galeria.length > 0 && (
        <GaleriaFotos siteConfig={siteConfig} />
      )}
      {bloques.contacto && siteConfig.contacto && (
        <ContactoSection siteConfig={siteConfig} />
      )}
    </main>
    <SiteFooter siteConfig={siteConfig} />

    <style is:global>
      @import "../styles/global.css";
      body {
        font-family: "Inter", system-ui, sans-serif;
      }
      @media (prefers-reduced-motion: reduce) {
        *, *::before, *::after {
          animation-duration: 0.01ms !important;
          animation-iteration-count: 1 !important;
          transition-duration: 0.01ms !important;
          scroll-behavior: auto !important;
        }
      }
    </style>
  </body>
</html>
