---
import type { SiteConfig } from "../lib/api";

interface Props {
  siteConfig: SiteConfig;
}

const { siteConfig } = Astro.props;
const about = siteConfig.sobreNosotros!;
---

<section id="sobre-nosotros" class="max-w-6xl mx-auto px-4 md:px-6 py-16 md:py-20">
  <div class="grid gap-10 md:grid-cols-2 md:items-center">
    <div>
      <div
        class="text-xs font-semibold tracking-widest uppercase mb-3"
        style="color: var(--color-tema);"
      >
        Sobre nosotros
      </div>
      <h2 class="text-3xl md:text-4xl font-extrabold tracking-tight mb-5">
        Cultura, comunidad y participación
      </h2>
      <div class="space-y-4 text-neutral-700 leading-relaxed">
        {about.texto.map((parrafo) => <p>{parrafo}</p>)}
      </div>
      <a
        href="#contacto"
        class="inline-flex items-center mt-6 px-5 py-2.5 rounded-lg text-sm font-semibold border border-neutral-300 hover:border-[color:var(--color-tema)] hover:text-[color:var(--color-tema)] transition-colors"
      >
        Leer más sobre nosotros
      </a>
    </div>

    <div class="order-first md:order-last">
      <img
        src={about.imagenUrl}
        alt=""
        loading="lazy"
        class="w-full h-80 md:h-96 object-cover rounded-2xl shadow-sm"
      />
    </div>
  </div>
</section>
