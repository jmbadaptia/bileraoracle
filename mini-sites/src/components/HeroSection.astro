---
import type { SiteConfig } from "../lib/api";

interface Props {
  siteConfig: SiteConfig;
}

const { siteConfig } = Astro.props;
const { nombre, subtitulo, categoria, ciudad, socios, heroImageUrl, bloques } = siteConfig;
---

<section class="relative w-full h-[420px] overflow-hidden">
  <img
    src={heroImageUrl}
    alt=""
    class="absolute inset-0 w-full h-full object-cover"
    loading="eager"
    fetchpriority="high"
  />
  <div
    class="absolute inset-0"
    style="background: linear-gradient(to top, rgba(0,0,0,.75) 0%, rgba(0,0,0,.3) 50%, rgba(0,0,0,.1) 100%);"
    aria-hidden="true"
  ></div>

  <div class="relative h-full max-w-6xl mx-auto px-4 md:px-6 flex items-end pb-10 md:pb-14">
    <div class="text-white text-center md:text-left w-full">
      <div
        class="inline-flex items-center gap-2 text-xs font-semibold tracking-widest uppercase mb-3"
        style="color: var(--color-tema);"
      >
        <span class="inline-block h-1.5 w-1.5 rounded-full" style="background-color: var(--color-tema);"></span>
        {categoria} · {ciudad}
      </div>
      <h1 class="text-3xl md:text-5xl font-extrabold leading-tight tracking-tight mb-3">
        {nombre}
      </h1>
      <p class="text-base md:text-lg text-neutral-200 max-w-2xl mx-auto md:mx-0 mb-6">
        {subtitulo}
      </p>

      <div class="flex flex-wrap gap-3 justify-center md:justify-start mb-5">
        {bloques.eventos && (
          <a
            href="#eventos"
            class="inline-flex items-center px-5 py-2.5 rounded-lg text-sm font-semibold text-white shadow-lg hover:opacity-90 transition-opacity"
            style="background-color: var(--color-tema);"
          >
            Ver próximos eventos
          </a>
        )}
        {bloques.sobreNosotros && (
          <a
            href="#sobre-nosotros"
            class="inline-flex items-center px-5 py-2.5 rounded-lg text-sm font-semibold text-white bg-white/10 border border-white/40 backdrop-blur hover:bg-white/20 transition-colors"
          >
            Conócenos
          </a>
        )}
      </div>

      <div class="flex flex-wrap gap-5 text-sm text-white/90 justify-center md:justify-start">
        <span class="inline-flex items-center gap-1.5">
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
          </svg>
          {ciudad}
        </span>
        <span class="inline-flex items-center gap-1.5">
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" />
          </svg>
          +{socios} socios
        </span>
      </div>
    </div>
  </div>
</section>
