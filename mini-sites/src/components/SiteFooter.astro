---
import type { SiteConfig } from "../lib/api";

interface Props {
  siteConfig: SiteConfig;
}

const { siteConfig } = Astro.props;
const { nombre, bloques } = siteConfig;
const year = new Date().getFullYear();

const links = [
  { href: "#inicio", label: "Inicio", show: true },
  { href: "#eventos", label: "Eventos", show: bloques.eventos },
  { href: "#cursos", label: "Cursos", show: bloques.cursos },
  { href: "#galeria", label: "Galería", show: bloques.galeria },
  { href: "#contacto", label: "Contacto", show: bloques.contacto },
].filter((l) => l.show);
---

<footer class="bg-neutral-900 text-neutral-400">
  <div class="max-w-6xl mx-auto px-4 md:px-6">
    <div class="py-8 flex flex-wrap items-center justify-between gap-4 border-b border-neutral-800">
      <div class="flex items-center gap-2.5 text-white">
        <span
          class="h-8 w-8 rounded-lg flex items-center justify-center text-white text-sm font-bold"
          style="background-color: var(--color-tema);"
          aria-hidden="true"
        >
          {nombre.charAt(0)}
        </span>
        <span class="font-semibold text-sm">{nombre}</span>
      </div>

      <ul class="flex flex-wrap items-center gap-5 text-sm">
        {links.map((link) => (
          <li>
            <a href={link.href} class="hover:text-white transition-colors">{link.label}</a>
          </li>
        ))}
      </ul>
    </div>

    <div class="py-6 flex flex-wrap items-center justify-between gap-3 text-xs">
      <div>© {year} {nombre}. Todos los derechos reservados.</div>
      <div>
        Presencia web con{" "}
        <a
          href="https://gruppia.com"
          target="_blank"
          rel="noopener noreferrer"
          class="text-white font-semibold hover:underline"
        >
          Gruppia
        </a>
      </div>
    </div>
  </div>
</footer>
