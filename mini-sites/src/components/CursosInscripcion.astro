---
import type { SiteConfig } from "../lib/api";

interface Props {
  siteConfig: SiteConfig;
}

const { siteConfig } = Astro.props;
const cursos = siteConfig.cursos!;
---

<section id="cursos" class="bg-[#fafaf8] py-16 md:py-20">
  <div class="max-w-6xl mx-auto px-4 md:px-6">
    <div class="flex items-end justify-between mb-8 flex-wrap gap-3">
      <div>
        <div
          class="text-xs font-semibold tracking-widest uppercase mb-2"
          style="color: var(--color-tema);"
        >
          Cursos con inscripción abierta
        </div>
        <h2 class="text-2xl md:text-3xl font-extrabold tracking-tight">
          Apúntate a nuestros cursos
        </h2>
      </div>
      <a
        href="#"
        class="text-sm font-semibold hover:underline"
        style="color: var(--color-tema);"
      >
        Ver todos los cursos →
      </a>
    </div>

    <div class="grid gap-5" style="grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));">
      {cursos.map((curso) => (
        <article class="bg-white rounded-xl overflow-hidden border border-neutral-200 hover:shadow-md transition-shadow flex flex-col">
          <div class="h-36 overflow-hidden">
            <img
              src={curso.imagenUrl}
              alt=""
              loading="lazy"
              class="w-full h-full object-cover"
            />
          </div>
          <div class="p-4 space-y-2 flex-1 flex flex-col">
            <h3 class="font-semibold leading-snug">{curso.titulo}</h3>
            <div class="text-sm text-neutral-600 flex items-center gap-1.5">
              <span aria-hidden="true">📅</span>
              <span>{curso.horario}</span>
            </div>
            <div class="text-sm text-neutral-600 flex items-center gap-1.5">
              <span aria-hidden="true">🎟</span>
              <span>{curso.plazas} plazas disponibles</span>
            </div>
            <div class="flex items-center justify-between pt-2 mt-auto">
              <span class="font-extrabold text-lg" style="color: var(--color-tema);">
                {curso.precio === null ? "Gratis" : `${curso.precio} €`}
              </span>
              <a
                href={curso.inscripcionUrl}
                class="inline-flex items-center px-3.5 py-1.5 rounded-full text-xs font-semibold text-white shadow-sm hover:opacity-90 transition-opacity"
                style="background-color: var(--color-tema);"
              >
                Inscribirse
              </a>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
