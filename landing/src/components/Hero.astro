---
const APP_URL = import.meta.env.PUBLIC_APP_URL || "http://localhost:3001";
---

<section class="pt-32 pb-20 px-6">
  <div class="max-w-4xl mx-auto text-center">
    <div class="inline-flex items-center px-3 py-1 rounded-full bg-primary/10 text-primary text-sm font-medium mb-6">
      Gratis para empezar
    </div>
    <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight leading-[1.1] text-gray-900">
      La plataforma para gestionar
      <span class="text-primary"> tu organización</span>
    </h1>
    <p class="mt-6 text-lg sm:text-xl text-gray-600 max-w-2xl mx-auto leading-relaxed">
      Personas, actividades, documentos, espacios y un asistente con IA.
      Todo lo que necesita tu equipo, en un solo sitio.
    </p>
    <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href={`${APP_URL}/registro`}
        class="inline-flex items-center px-8 py-3.5 rounded-xl bg-primary text-white font-semibold text-base hover:bg-primary/90 transition-colors shadow-lg shadow-primary/25"
      >
        Empieza gratis
      </a>
      <a
        href="#features"
        class="inline-flex items-center px-8 py-3.5 rounded-xl border border-gray-200 text-gray-700 font-semibold text-base hover:bg-gray-50 transition-colors"
      >
        Ver funcionalidades
      </a>
    </div>
  </div>

  <!-- App mockup -->
  <div class="mt-20 max-w-5xl mx-auto rounded-2xl bg-white border border-gray-200 shadow-2xl shadow-gray-200/50 overflow-hidden">
    <!-- Browser chrome -->
    <div class="flex items-center gap-2 px-4 py-3 bg-gray-50 border-b border-gray-200">
      <div class="flex gap-1.5">
        <div class="w-3 h-3 rounded-full bg-gray-300"></div>
        <div class="w-3 h-3 rounded-full bg-gray-300"></div>
        <div class="w-3 h-3 rounded-full bg-gray-300"></div>
      </div>
      <div class="flex-1 mx-4">
        <div class="h-6 bg-gray-200 rounded-md max-w-xs mx-auto"></div>
      </div>
    </div>
    <!-- App content mockup -->
    <div class="flex h-64 sm:h-80">
      <!-- Sidebar -->
      <div class="w-16 sm:w-48 bg-gray-50 border-r border-gray-100 p-3 space-y-2 shrink-0">
        <div class="h-6 w-6 sm:w-full rounded-md bg-primary/20"></div>
        <div class="mt-4 space-y-1.5">
          <div class="h-4 w-6 sm:w-3/4 rounded bg-gray-200"></div>
          <div class="h-4 w-6 sm:w-2/3 rounded bg-primary/15"></div>
          <div class="h-4 w-6 sm:w-4/5 rounded bg-gray-200"></div>
          <div class="h-4 w-6 sm:w-1/2 rounded bg-gray-200"></div>
          <div class="h-4 w-6 sm:w-3/5 rounded bg-gray-200"></div>
        </div>
      </div>
      <!-- Main area -->
      <div class="flex-1 p-4 sm:p-6 space-y-4">
        <div class="flex gap-3">
          <div class="h-8 w-32 rounded-md bg-gray-200"></div>
          <div class="h-8 w-8 rounded-md bg-primary/15 ml-auto"></div>
        </div>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
          <div class="h-16 sm:h-20 rounded-lg bg-gradient-to-br from-primary/10 to-primary/5 border border-primary/10"></div>
          <div class="h-16 sm:h-20 rounded-lg bg-gradient-to-br from-blue-50 to-blue-100/50 border border-blue-100"></div>
          <div class="hidden sm:block h-20 rounded-lg bg-gradient-to-br from-violet-50 to-violet-100/50 border border-violet-100"></div>
          <div class="hidden sm:block h-20 rounded-lg bg-gradient-to-br from-emerald-50 to-emerald-100/50 border border-emerald-100"></div>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 flex-1">
          <div class="sm:col-span-2 h-24 sm:h-32 rounded-lg bg-gray-50 border border-gray-100 p-3">
            <div class="space-y-2">
              <div class="h-3 w-1/3 rounded bg-gray-200"></div>
              <div class="h-2 w-full rounded bg-gray-100"></div>
              <div class="h-2 w-4/5 rounded bg-gray-100"></div>
              <div class="h-2 w-2/3 rounded bg-gray-100"></div>
            </div>
          </div>
          <div class="hidden sm:block h-32 rounded-lg bg-gray-50 border border-gray-100 p-3">
            <div class="space-y-2">
              <div class="h-3 w-1/2 rounded bg-gray-200"></div>
              <div class="flex gap-1 mt-3">
                <div class="h-6 w-6 rounded-full bg-primary/20"></div>
                <div class="h-6 w-6 rounded-full bg-blue-200"></div>
                <div class="h-6 w-6 rounded-full bg-violet-200"></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
