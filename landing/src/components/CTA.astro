---
const APP_URL = import.meta.env.PUBLIC_APP_URL || "http://localhost:3001";
---

<section class="py-20 px-6">
  <div class="max-w-3xl mx-auto text-center bg-gradient-to-br from-primary to-rose-600 rounded-3xl p-12 sm:p-16">
    <h2 class="text-3xl sm:text-4xl font-bold text-white tracking-tight">
      ¿Listo para empezar?
    </h2>
    <p class="mt-4 text-lg text-white/80">
      Crea tu espacio en menos de un minuto. Sin tarjeta de crédito.
    </p>
    <a
      href={`${APP_URL}/registro`}
      class="mt-8 inline-flex items-center px-8 py-3.5 rounded-xl bg-white text-primary font-semibold text-base hover:bg-gray-50 transition-colors shadow-lg"
    >
      Crear mi organización
    </a>
  </div>
</section>
